# Phone
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15555550100

# STT
DEEPGRAM_API_KEY=your_deepgram_api_key

# LLM
GEMINI_API_KEY=your_gemini_api_key

# TTS
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id

# Avatar
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=

# Google Meet (automation)
# If Meet shows "You can't join this video call", try in order:
# 1) MEET_USE_CHROME_CHANNEL=true  — use installed Google Chrome instead of bundled Chromium
# 2) Sign in at google.com in the Meet browser profile (.browser-profile-meet) so you join as a real user
# 3) MEET_USE_FAKE_MEDIA=0  — disable Playwright fake media flags (use real mic/cam prompts)
# 4) Ensure the meeting allows your account (workspace-only meetings block guests)
# MEET_USE_CHROME_CHANNEL=false
# MEET_USE_FAKE_MEDIA=
# MEET_USER_AGENT=
# MEETING_PHONE_PARITY=true — respond to every utterance like phone mode (default: off; uses meeting wake-word behavior)

# Server
# For phone calls from Twilio: tunnel this machine’s API (default PORT) and put the public
# hostname here — host only, no https:// (e.g. abc123.ngrok-free.app).
# 1) npm run tunnel:server   (repo root, or `cd server` — same script; or: ngrok http 3001)
#    ERR_NGROK_334: that ngrok hostname is already online (another terminal/agent). Quit the
#    existing ngrok first, or keep using the running tunnel—no second tunnel needed.
# 2) npm run tunnel:sync-env   (repo root or `cd server`; writes SERVER_URL from ngrok’s API)
#    Or copy the “Forwarding” https URL host into SERVER_URL manually
# 3) In Twilio Console → Phone Numbers → your # → Voice webhook:
#    https://YOUR_HOST/api/twilio/voice   method POST
# 4) Restart: npm run dev:server (or npm run dev)
SERVER_URL=
PORT=3001

# Dashboard (optional override)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
