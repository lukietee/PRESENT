# Phone
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# STT
DEEPGRAM_API_KEY=

# LLM
GEMINI_API_KEY=

# TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Avatar
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=

# Server
# For phone calls from Twilio: tunnel this machine’s API (default PORT) and put the public
# hostname here — host only, no https:// (e.g. abc123.ngrok-free.app).
# 1) npm run tunnel:server   (or: ngrok http 3001)
# 2) Copy the “Forwarding” https URL host into SERVER_URL
# 3) In Twilio Console → Phone Numbers → your # → Voice webhook:
#    https://YOUR_HOST/api/twilio/voice   method POST
# 4) Restart: npm run dev:server (or npm run dev)
SERVER_URL=
PORT=3001

# Dashboard (optional override)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
